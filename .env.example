# Public PostHog project key (safe to expose). A default is also hardcoded in
# PostHogProvider.tsx, so this is only needed to override (e.g. a staging key).
NEXT_PUBLIC_POSTHOG_KEY=phc_pkRrtTu2YFEn3TjSzhUcoU8NQrcDRA2JKkhPiwt8MheD
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Server-side rewrite targets for the /ingest reverse proxy.
# Use the EU values if your PostHog project is in the EU region:
# POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_ASSET_HOST=https://eu-assets.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ASSET_HOST=https://us-assets.i.posthog.com

# SEO — canonical production domain used for sitemap URLs, canonical tags,
# OpenGraph, and JSON-LD. Must be the non-redirecting host: the apex
# shopyacu.com redirects to www, so use the www version.
NEXT_PUBLIC_SITE_URL=https://www.shopyacu.com

# Google Search Console verification token (optional). Paste the value from the
# "HTML tag" verification method to verify the property and submit the sitemap.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# OpenAI / ChatGPT API — used by `npm run generate:blog` to mass-generate
# SEO-optimised blog posts into MongoDB. Only needed when running that script
# (not at runtime). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: override the model (default gpt-4o-mini, cheap & good for articles).
OPENAI_MODEL=gpt-4o-mini
